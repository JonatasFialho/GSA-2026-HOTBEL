            function matrizAtualizarKPIs() {
                let somaMetaGlobal = 0, somaRealGlobal = 0;
                let alvo = matrizVisaoAtual === 'VENDEDORES' ? matrizDadosEquipe : matrizDadosSupervisores;
                alvo.forEach(item => {
                    if (matrizMetricaAtual === 'SELLOUT') {
                        somaMetaGlobal += item.limpeza.metaValor + item.higiene.metaValor + item.beleza.metaValor;
                        somaRealGlobal += item.limpeza.realValor + item.higiene.realValor + item.beleza.realValor;
                    } else {
                        somaMetaGlobal += item.total.metaPosit;
                        somaRealGlobal += item.total.clientesSet.size;
                    }
                });
                const percentualGlobal = (somaMetaGlobal > 0) ? (somaRealGlobal / somaMetaGlobal) * 100 : 0;
                
                const fmt = matrizMetricaAtual === 'SELLOUT' ? matrizFormatarMoeda : (v) => new Intl.NumberFormat('pt-BR').format(v);
                const lblSuf = matrizMetricaAtual === 'SELLOUT' ? '(R$)' : '(Cli)';

                const elLblMeta = document.getElementById('matriz-kpi-lbl-meta');
                const elLblReal = document.getElementById('matriz-kpi-lbl-real');
                if (elLblMeta) elLblMeta.innerText = `Meta Total LHB ${lblSuf}`;
                if (elLblReal) elLblReal.innerText = `Realizado Total ${lblSuf}`;

                const elMeta = document.getElementById('matriz-kpi-meta');
                const elReal = document.getElementById('matriz-kpi-real');
                const elAtg = document.getElementById('matriz-kpi-atingimento');
                const elBar = document.getElementById('matriz-kpi-progress-bar');
                
                if (elMeta) elMeta.innerText = fmt(somaMetaGlobal);
                if (elReal) elReal.innerText = fmt(somaRealGlobal);
                if (elAtg) {
                    elAtg.innerText = `${percentualGlobal.toFixed(1)}%`;
                    if (percentualGlobal === 0) elAtg.className = 'text-4xl font-black text-muted';
                    else if (percentualGlobal < 95) elAtg.className = 'text-4xl font-black text-danger';
                    else if (percentualGlobal < 100) elAtg.className = 'text-4xl font-black text-warning';
                    else elAtg.className = 'text-4xl font-black text-success';
                }
                if (elBar) {
                    elBar.style.width = `${Math.min(percentualGlobal, 100)}%`;
                    if (percentualGlobal === 0) elBar.className = 'h-full bg-secondary transition-all duration-500';
                    else if (percentualGlobal < 95) elBar.className = 'h-full bg-danger transition-all duration-500';
                    else if (percentualGlobal < 100) elBar.className = 'h-full bg-warning transition-all duration-500';
                    else elBar.className = 'h-full bg-success transition-all duration-500';
                }
            }

            atualizarMatrizComArquivos = async function(filesArray, isScript = false) {
                let fM = filesArray.find(f => f.name.toUpperCase().includes('META')); 
                
                // Fallback Inteligente: Se não achar a palavra 'META' no título, procura por dentro do texto do arquivo
                if (!fM && isScript) {
                    fM = filesArray.find(f => f.content && (f.content.includes('META LIMPEZA') || f.content.includes('META HIGIENE') || f.content.includes('META BELEZA')));
                }
                
                let fV = filesArray.filter(f => f.name.toUpperCase().startsWith('BD-'));
                
                if (isScript && !fM) {
                    alert("⚠️ ALERTA DA MATRIZ DE VENDAS ⚠️\n\nO Script não conseguiu puxar seu arquivo de METAS.\n\nMOTIVO: Pelo seu Google Drive, o arquivo de metas pode estar no formato Excel (.xlsx) ou com nome irreconhecível. O Apps Script só lê arquivos '.csv'.\n\nCOMO RESOLVER: Abra o arquivo de metas no Excel, clique em 'Salvar como' -> 'CSV (separado por vírgulas)', garanta que o nome tenha a palavra 'META' e suba essa versão na sua pasta.");
                    return;
                }

                if (!fM || fV.length === 0) {
                    console.log('Ficheiros META ou BD- não encontrados no lote carregado. A aba Matriz manter-se-á inalterada ou vazia.');
                    return;
                }
                
                try {
                    matrizDadosMetasPorMes = await matrizLerArquivo(fM, true, isScript); 
                    matrizDadosVendasPorMes = {};
                    
                    const rV = await Promise.all(fV.map(f => matrizLerArquivo(f, false, isScript).then(data => ({ name: f.name, data }))));
                    
                    rV.forEach(res => { 
                        const m = matrizIdentificarMes(res.name, res.data); 
                        if (!matrizDadosVendasPorMes[m]) matrizDadosVendasPorMes[m] = []; 
                        matrizDadosVendasPorMes[m] = matrizDadosVendasPorMes[m].concat(res.data); 
                    });
                    
                    matrizSupervisoresSet.clear(); 
                    Object.values(matrizDadosMetasPorMes).forEach(sh => sh.forEach(r => { if (r['SUPERVISOR']) matrizSupervisoresSet.add(String(r['SUPERVISOR']).trim()); }));
                    
                    const selectMes = document.getElementById('matriz-filtro-mes');
                    const selectSup = document.getElementById('matriz-filtro-supervisor');
                    
                    if (selectMes) {
                        selectMes.innerHTML = ''; 
                        Object.keys(matrizDadosVendasPorMes).sort().forEach(m => selectMes.innerHTML += `<option value="${m}">${m}</option>`);
                    }
                    if (selectSup) {
                        selectSup.innerHTML = '<option value="Todos">Todas as Equipes</option>'; 
                        Array.from(matrizSupervisoresSet).sort().forEach(s => selectSup.innerHTML += `<option value="${s}">${s}</option>`);
                    }
                    
                    const fContainer = document.getElementById('matriz-filtros-container');
                    if(fContainer) fContainer.classList.remove('hidden');
                    
                    matrizCruzarDados();
                    matrizRenderizarTabela();
                    matrizAtualizarKPIs();
                    
                } catch (error) { 
                    console.error('Erro ao processar dados da Matriz de Vendas:', error); 
                }
            };

