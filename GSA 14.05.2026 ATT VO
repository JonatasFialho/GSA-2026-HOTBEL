        const formatCurrency = (value) => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value);
        const formatNumber = (value) => new Intl.NumberFormat('pt-BR').format(value);

        function parseMetaValue(val) {
            if (!val && val !== 0) return 0;
            let str = String(val).replace(/R\$\s?/ig, '').trim(); 
            if (str.includes('.') && str.includes(',')) {
                if (str.lastIndexOf(',') > str.lastIndexOf('.')) {
                    str = str.replace(/\./g, '').replace(',', '.');
                } else {
                    str = str.replace(/,/g, '');
                }
            } else if (str.includes(',')) {
                str = str.replace(',', '.');
            }
            return parseFloat(str) || 0;
        }

        function findKeyPartial(row, searchStr) {
            const search = searchStr.toUpperCase().replace(/[\s_]/g, '');
            for (let key in row) {
                if (key && typeof key === 'string') {
                    const cleanKey = key.toUpperCase().replace(/[\s_]/g, '');
                    if (cleanKey.includes(search)) return row[key];
                }
            }
            return undefined;
        }

        function processRowData(row, sourceName = '') {
            let vlFatStr = String(row['VLFAT'] || '0').replace(/R\$\s?/ig, '').trim();
            if (vlFatStr.includes(',') && vlFatStr.includes('.')) {
                if (vlFatStr.lastIndexOf(',') > vlFatStr.lastIndexOf('.')) vlFatStr = vlFatStr.replace(/\./g, '').replace(',', '.');
                else vlFatStr = vlFatStr.replace(/,/g, '');
            } else if (vlFatStr.includes(',')) vlFatStr = vlFatStr.replace(',', '.');
            let vlFat = parseFloat(vlFatStr) || 0;

            let qtdStr = String(row['QT_UN'] || row['QTD'] || row['QUANTIDADE'] || row['QTDE'] || row['QUANT'] || '0').replace(/\./g, '').replace(',', '.');
            let qtdNum = parseFloat(qtdStr) || 0;
            if (qtdNum === 0 && vlFat > 0) qtdNum = 1; 

            let mesAno = '00';
            if (row['DTINI']) {
                let dt = String(row['DTINI']).trim().split(' ')[0];
                if (dt.includes('/')) mesAno = dt.split('/')[1]?.padStart(2, '0') || '00';
                else if (dt.includes('-')) mesAno = dt.split('-')[1]?.padStart(2, '0') || '00';
            }
            
            if (mesAno === '00' && sourceName) {
                const sn = sourceName.toUpperCase();
                if (sn.includes('JAN')) mesAno = '01';
                else if (sn.includes('FEV')) mesAno = '02';
                else if (sn.includes('MAR')) mesAno = '03';
                else if (sn.includes('ABR')) mesAno = '04';
                else if (sn.includes('MAI')) mesAno = '05';
                else if (sn.includes('JUN')) mesAno = '06';
                else if (sn.includes('JUL')) mesAno = '07';
                else if (sn.includes('AGO')) mesAno = '08';
                else if (sn.includes('SET')) mesAno = '09';
                else if (sn.includes('OUT')) mesAno = '10';
                else if (sn.includes('NOV')) mesAno = '11';
                else if (sn.includes('DEZ')) mesAno = '12';
            }

            let deptRaw = String(row['DEPARTAMENTO'] || '').toUpperCase().trim();
            let dept = 'OUTROS';
            if(deptRaw.includes('LIM')) dept = 'LIM';
            else if(deptRaw.includes('HIG') || deptRaw.includes('HB')) dept = 'HIG';
            else if(deptRaw.includes('BEL')) dept = 'BEL';

            let metaLimpeza = parseMetaValue(findKeyPartial(row, 'META LIMPEZA'));
            let positLimpeza = parseMetaValue(findKeyPartial(row, 'POSIT LIMPEZA'));
            let metaHigiene = parseMetaValue(findKeyPartial(row, 'META HIGIENE'));
            let positHigiene = parseMetaValue(findKeyPartial(row, 'POSIT HIGIENE'));
            let metaBeleza = parseMetaValue(findKeyPartial(row, 'META BELEZA'));
            let positBeleza = parseMetaValue(findKeyPartial(row, 'POSIT BELEZA'));
            let metaGeral = parseMetaValue(findKeyPartial(row, 'META GERAL'));

            let sup = String(row['SUPERVISOR'] || findKeyPartial(row, 'SUPERVISOR') || '').trim();
            let vend = String(row['VENDEDOR'] || findKeyPartial(row, 'VENDEDOR') || '').trim();

            let codVendRaw = row['CODVEND'] || row['CODRCA'] || row['CODUSUR'] || findKeyPartial(row, 'CODVEND') || findKeyPartial(row, 'CODRCA') || findKeyPartial(row, 'CODUSUR');
            let codVend = String(codVendRaw || '').trim();

            let codSupRaw = row['CODSUPERVISOR'] || findKeyPartial(row, 'CODSUPERVISOR');
            let codSup = String(codSupRaw || '').trim();

            let rawCidade = row['Nome Cidades'] || row['CIDADE'] || '';
            let cidadeLimpa = '';
            if (rawCidade && String(rawCidade).trim() !== '') {
                cidadeLimpa = String(rawCidade).normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase().replace(/\s+/g, ' ').replace(/\s*-\s*/g, ' - ').trim();
            }

            return { 
                ...row, 
                SUPERVISOR: sup, 
                VENDEDOR: vend, 
                CODVEND: codVend,
                CODSUPERVISOR: codSup,
                VLFAT_NUM: vlFat, 
                QTD_NUM: qtdNum, 
                MES_EXTRATO: mesAno, 
                DEPT_NORM: dept,
                CIDADE_LIMPA: cidadeLimpa,
                META_LIMPEZA: metaLimpeza,
                POSIT_LIMPEZA: positLimpeza,
                META_HIGIENE: metaHigiene,
                POSIT_HIGIENE: positHigiene,
                META_BELEZA: metaBeleza,
                POSIT_BELEZA: positBeleza,
                META_GERAL: metaGeral
            };
        }

        async function syncFromGoogleDriveScript() {
            if (!GOOGLE_APPS_SCRIPT_URL) {
                alert("O link do Google Apps Script não foi configurado.\nCole o link gerado no tutorial na variável 'GOOGLE_APPS_SCRIPT_URL' dentro do código deste arquivo.");
                return;
            }
            document.getElementById('loading-overlay').style.display = 'flex';
            document.getElementById('loading-text').innerText = "Conectando ao Google Drive...";
            document.getElementById('loading-subtext').innerText = "Executando o Apps Script para baixar os arquivos...";

            try {
                const response = await fetch(GOOGLE_APPS_SCRIPT_URL);
                const data = await response.json();

                if (!data || data.length === 0) {
                    alert("A pasta do Drive está vazia ou o script não encontrou arquivos CSV.");
                    document.getElementById('loading-overlay').style.display = 'none';
                    return;
                }
                document.getElementById('loading-text').innerText = `Processando ${data.length} arquivo(s) via Script...`;
                
                // --- Integração Automática com a Aba Matriz de Vendas ---
                if (typeof atualizarMatrizComArquivos === 'function') {
                    atualizarMatrizComArquivos(data, true);
                }
                // --------------------------------------------------------

                globalData = [];
                let filesProcessed = 0;

                data.forEach(fileData => {
                    const fName = fileData.name.toLowerCase();
                    if (fName.endsWith('.csv')) {
                        Papa.parse(fileData.content, {
                            header: true, skipEmptyLines: true, dynamicTyping: false,
                            complete: function(results) {
                                const parsedRows = results.data.map(row => processRowData(row, fileData.name));
                                globalData = globalData.concat(parsedRows);
                                filesProcessed++;
                                if (filesProcessed === data.length) finalizeDataLoading();
                            },
                            error: function(err) {
                                console.error("Erro no PapaParse:", fileData.name, err);
                                filesProcessed++;
                                if (filesProcessed === data.length) finalizeDataLoading();
                            }
                        });
                    } else {
                        // Ignora arquivos que não são CSV para não quebrar a leitura
                        filesProcessed++;
                        if (filesProcessed === data.length) finalizeDataLoading();
                    }
                });
            } catch (error) {
                console.error("Erro no Apps Script:", error);
                alert("Falha ao comunicar com o Google Apps Script. Verifique se publicou o Web App corretamente.\nErro técnico: " + error.message);
                document.getElementById('loading-overlay').style.display = 'none';
            }
        }

        document.getElementById('csv-upload').addEventListener('change', async function(e) {
            const files = e.target.files;
            if (!files || files.length === 0) return;
            
            const filesToProcess = Array.from(files).filter(file => 
                file.name.toLowerCase().endsWith('.csv') || 
                file.name.toLowerCase().endsWith('.xlsx') || 
                file.name.toLowerCase().endsWith('.xls')
            );

            if (filesToProcess.length === 0) { alert('Nenhum CSV ou Excel (.xlsx) encontrado.'); return; }

            document.getElementById('loading-overlay').style.display = 'flex';
            document.getElementById('loading-text').innerText = `Processando ${filesToProcess.length} arquivo(s) localmente...`;
            
            // --- Integração Automática com a Aba Matriz de Vendas ---
            if (typeof atualizarMatrizComArquivos === 'function') {
                atualizarMatrizComArquivos(Array.from(files), false);
            }
            // --------------------------------------------------------

            globalData = [];
            let filesProcessed = 0;

            for (let i = 0; i < filesToProcess.length; i++) {
                const file = filesToProcess[i];
                
                if (file.name.toLowerCase().endsWith('.csv')) {
                    Papa.parse(file, {
                        header: true, skipEmptyLines: true, dynamicTyping: false,
                        complete: function(results) {
                            globalData = globalData.concat(results.data.map(row => processRowData(row, file.name)));
                            filesProcessed++;
                            if (filesProcessed === filesToProcess.length) finalizeDataLoading();
                        },
                        error: function(err) {
                            filesProcessed++;
                            if (filesProcessed === filesToProcess.length) finalizeDataLoading();
                        }
                    });
                } 
                else if (file.name.toLowerCase().endsWith('.xlsx') || file.name.toLowerCase().endsWith('.xls')) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        try {
                            const data = new Uint8Array(e.target.result);
                            const workbook = XLSX.read(data, {type: 'array'});
                            
                            workbook.SheetNames.forEach(sheetName => {
                                const sheet = workbook.Sheets[sheetName];
