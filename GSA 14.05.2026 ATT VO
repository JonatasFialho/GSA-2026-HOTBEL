        let tableData = [];
        function renderTable() {
            const mapCidades = new Map();
            
            const sups = getCustomSelectValues('filter-supervisor');
            const vends = getCustomSelectValues('filter-vendedor');

            globalData.forEach(row => {
                if (sups.length > 0 && !sups.includes(row.SUPERVISOR)) return;
                if (vends.length > 0 && !vends.includes(row.VENDEDOR)) return;

                const cidade = row.CIDADE_LIMPA;
                if (!cidade) return;

                if (!mapCidades.has(cidade)) {
                    mapCidades.set(cidade, { cidade: row['Nome Cidades'] || row.CIDADE || 'Não Informada', lim: 0, hig: 0, bel: 0, total: 0 });
                }
            });

            filteredData.forEach(row => {
                const cidade = row.CIDADE_LIMPA;
                if (!cidade) return;

                const entry = mapCidades.get(cidade);
                if (entry) {
                    const val = row.VLFAT_NUM;
                    entry.total += val;
                    if (row.DEPT_NORM === 'LIM') entry.lim += val;
                    else if (row.DEPT_NORM === 'HIG') entry.hig += val;
                    else if (row.DEPT_NORM === 'BEL') entry.bel += val;
                }
