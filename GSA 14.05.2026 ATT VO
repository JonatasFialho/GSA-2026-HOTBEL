<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Dashboard Comercial - Integração via Apps Script</title>

    <!-- Favicon -->
    <link rel="icon" href="https://megamix.ind.br/wp-content/uploads/2017/06/condor-logo.png" type="image/png">

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    <!-- TAILWIND CSS (Carregado de forma segura sem quebrar o Bootstrap) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            corePlugins: {
                preflight: false, // Previne que o Tailwind destrua os estilos do Bootstrap!
            }
        }
    </script>

    <style>
        :root {
            --primary-color: #0f4c81; /* Classic Blue */
            --bg-color: #f4f7f6;
            --header-bg: #ffffff;
            --card-bg: #eef5fb; 
            --text-dark: #2d3436;
            --text-muted: #636e72;
            --border-color: #d9e8f5; 
            --kpi-border-color: #6ba0d6; 
            --content-border-color: #6ba0d6; 
            --meta-chart-border: #6ba0d6; 
            --icon-bg: #ffffff;
            --header-title-color: var(--primary-color);
            --header-subtext-color: var(--text-muted);
        }

        [data-theme="light-red-cards"] {
            --primary-color: #c0392b;
            --bg-color: #f4f7f6;
            --header-bg: #ffffff;
            --card-bg: #fff0f0;
            --text-dark: #2d3436;
            --text-muted: #636e72;
            --border-color: #fadbd8; 
            --kpi-border-color: #e74c3c; 
            --content-border-color: #e74c3c; 
            --meta-chart-border: #e74c3c; 
            --icon-bg: #ffffff;
            --header-title-color: var(--primary-color);
            --header-subtext-color: var(--text-muted);
        }

        [data-theme="red-bg"] {
            --primary-color: #922b21; 
            --bg-color: #fadbd8;
            --header-bg: #c0392b; 
            --card-bg: #ffffff;
            --text-dark: #2d3436;
            --text-muted: #636e72;
            --border-color: #f1eaeb;
            --kpi-border-color: #f1eaeb;
            --content-border-color: #f1eaeb;
            --meta-chart-border: #f1eaeb;
            --icon-bg: #f8f9fa;
            --header-title-color: #ffffff; 
            --header-subtext-color: rgba(255, 255, 255, 0.85); 
        }

        [data-theme="dark"] {
            --primary-color: #3498db;
            --bg-color: #1a1a24;
            --header-bg: #27293d;
            --card-bg: #27293d;
            --text-dark: #e0e0e0;
            --text-muted: #a0a0b0;
            --border-color: #2b3553;
            --kpi-border-color: #2b3553;
            --content-border-color: #2b3553;
            --meta-chart-border: #2b3553;
            --icon-bg: #1e1e2f;
            --header-title-color: var(--primary-color);
            --header-subtext-color: var(--text-muted);
        }

        /* -------------------------------------
           RESPONSIVIDADE ESTRUTURAL GLOBAL
           ------------------------------------- */
        html, body {
            overflow-x: clip; 
            width: 100%;
        }

        .text-dark { color: var(--text-dark) !important; }
        .text-muted { color: var(--text-muted) !important; }
        .text-primary { color: var(--primary-color) !important; }
        .bg-primary { background-color: var(--primary-color) !important; }
        
        .btn-outline-primary {
            color: var(--primary-color) !important;
            border-color: var(--primary-color) !important;
        }
        .btn-outline-primary:hover, .btn-check:checked + .btn-outline-primary {
            background-color: var(--primary-color) !important;
            color: white !important;
        }
        .btn-primary {
            background-color: var(--primary-color) !important;
            border-color: var(--primary-color) !important;
            color: white !important;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            color: var(--text-dark);
            transition: background-color 0.3s, color 0.3s;
        }

        .header-top {
            background: var(--header-bg);
            box-shadow: 0 2px 15px rgba(0,0,0,0.05);
            padding: 15px 0;
            position: relative;
            z-index: 1000;
            transition: background 0.3s;
        }

        .upload-btn-wrapper {
            position: relative;
            overflow: hidden;
            display: inline-block;
        }

        .upload-btn-wrapper input[type=file] {
            font-size: 100px;
            position: absolute;
            left: 0;
            top: 0;
            opacity: 0;
            cursor: pointer;
        }

        .card-kpi {
            background: var(--card-bg);
            border: 1px solid var(--kpi-border-color);
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.04);
            transition: transform 0.2s ease, background 0.3s, border-color 0.3s;
            height: 100%;
            min-height: 160px;
        }

        .card-kpi:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.08);
        }

        .kpi-title {
            font-size: 0.85rem;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--text-muted);
            letter-spacing: 0.5px;
            margin-bottom: 5px;
        }

        .kpi-value {
            font-size: 1.7rem;
            font-weight: 800;
            color: var(--text-dark);
            margin: 0;
            letter-spacing: -0.5px;
            word-wrap: break-word;
        }

        .icon-box {
            background: var(--icon-bg);
            border-radius: 8px;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            font-size: 1.1rem;
            flex-shrink: 0;
        }
        
        .badge-custom {
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            white-space: nowrap;
        }
        
        .badge-success { background: #e3fbee; color: #2ecc71; border: 1px solid rgba(46, 204, 113, 0.3); }
        .badge-warning { background: #fdf3d8; color: #f39c12; border: 1px solid rgba(243, 156, 18, 0.3); }
        .badge-danger { background: #fce4e4; color: #e74c3c; border: 1px solid rgba(231, 76, 60, 0.3); }

        .chart-container {
            background: var(--card-bg);
            border: 1px solid var(--content-border-color);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.04);
            margin-bottom: 24px;
            position: relative;
            height: 420px;
            transition: background 0.3s, border-color 0.3s;
            display: flex;
            flex-direction: column;
            width: 100%;
        }

        @media (max-width: 768px) {
            .chart-container {
                height: 350px;
                padding: 15px;
            }
        }

        .border-meta-charts {
            border: 1px solid var(--meta-chart-border) !important;
        }

        .chart-title {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 15px;
            color: var(--text-dark);
            border-bottom: 2px solid var(--border-color);
            padding-bottom: 10px;
            flex-shrink: 0;
            width: 100%;
        }

        .canvas-wrapper {
            position: relative;
            flex: 1;
            min-height: 0;
            width: 100%;
        }

        .filter-section {
            background: var(--card-bg);
            border: 1px solid var(--kpi-border-color);
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.04);
            margin-bottom: 24px;
            transition: background 0.3s, border-color 0.3s;
        }

        .form-select {
            border-radius: 8px;
            border: 1px solid var(--kpi-border-color);
            background-color: var(--card-bg);
            color: var(--text-dark);
        }

        /* FILTRO CUSTOMIZADO (MULTI-SELECT) */
        .custom-multi-select { position: relative; width: 100%; user-select: none; }
        .custom-multi-select .select-btn {
            display: flex; justify-content: space-between; align-items: center;
            padding: 8px 12px; background: var(--card-bg); border: 1px solid var(--kpi-border-color);
            border-radius: 8px; cursor: pointer; color: var(--text-dark); min-height: 38px; font-size: 0.95rem; transition: border-color 0.3s;
        }
        .custom-multi-select .select-btn:hover { border-color: var(--primary-color); }
        .custom-multi-select .btn-text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 90%; }
        .custom-multi-select .dropdown-content {
            display: none; position: absolute; top: 100%; left: 0; width: 100%; background: var(--card-bg);
            border: 1px solid var(--kpi-border-color); border-radius: 8px; margin-top: 4px; z-index: 1050;
            box-shadow: 0 8px 16px rgba(0,0,0,0.15); flex-direction: column;
        }
        .custom-multi-select.active .dropdown-content { display: flex; }
        .custom-multi-select .search-wrapper { padding: 10px; border-bottom: 1px solid var(--border-color); }
        .custom-multi-select .search-wrapper input { width: 100%; padding: 8px 12px; border: 1px solid var(--border-color); border-radius: 6px; background: transparent; color: var(--text-dark); outline: none; }
        .custom-multi-select .search-wrapper input:focus { border-color: var(--primary-color); box-shadow: 0 0 0 2px rgba(52, 152, 219, 0.2); }
        .custom-multi-select .options-list { overflow-y: auto; max-height: 250px; padding: 5px 0; }
        .custom-multi-select .options-list::-webkit-scrollbar { width: 6px; }
        .custom-multi-select .options-list::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 4px; }
        .custom-multi-select .option-item { padding: 8px 15px; display: flex; align-items: center; cursor: pointer; font-size: 0.9rem; color: var(--text-dark); margin: 0; }
        .custom-multi-select .option-item:hover { background: rgba(0,0,0,0.05); }
        [data-theme="dark"] .custom-multi-select .option-item:hover { background: rgba(255,255,255,0.08); }
        .custom-multi-select .option-item input[type="checkbox"] { margin-right: 10px; width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary-color); flex-shrink: 0; }

        /* Tabela Customizada */
        .table-custom-wrapper {
            background: var(--card-bg); border: 1px solid var(--content-border-color);
            border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.04);
            transition: background 0.3s, border-color 0.3s; width: 100%;
        }
        
        .table-custom { margin-bottom: 0; white-space: nowrap; }
        .table-custom th { background-color: var(--primary-color) !important; color: white !important; font-weight: 600; border: none; padding: 12px 16px; }
        .table-custom td { vertical-align: middle; border-bottom: 1px solid var(--border-color); color: var(--text-dark); padding: 12px 16px; background-color: var(--card-bg); transition: background 0.3s, color 0.3s; }
        
        @media (min-width: 992px) {
            .table-responsive { width: 100%; overflow: visible !important; }
            .table-scrollable { max-height: none !important; overflow: visible !important; }
            .table-custom-wrapper { overflow: visible !important; }
            
            .table-scrollable .table-custom th {
                position: -webkit-sticky !important;
                position: sticky !important;
                top: 0 !important; 
                z-index: 1050 !important;
                box-shadow: 0 4px 6px -2px rgba(0,0,0,0.15) !important;
            }
            .table-custom th:first-child, .table-custom td:first-child { position: sticky !important; left: 0; z-index: 1051 !important; border-right: 2px solid var(--border-color); }
            .table-scrollable .table-custom th:first-child { z-index: 1052 !important; }
        }

        @media (max-width: 991px) {
            .table-responsive { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; }
            .table-scrollable { max-height: 75vh; overflow-y: auto; }
            .table-scrollable .table-custom th { position: sticky; top: 0; z-index: 10; box-shadow: 0 4px 6px -2px rgba(0,0,0,0.15); }
            @media (min-width: 768px) {
                .table-custom th:first-child, .table-custom td:first-child { position: sticky; left: 0; z-index: 11; border-right: 2px solid var(--border-color); }
                .table-scrollable .table-custom th:first-child { z-index: 12; }
            }
        }

        .modal-body { overflow-x: auto; }
        .modal-body .table-responsive { overflow: visible; }
        .modal-body .table-custom th { position: sticky; top: 0; z-index: 10; box-shadow: 0 4px 6px -2px rgba(0,0,0,0.15); }
        @media (min-width: 768px) { .modal-body .table-custom th:first-child { z-index: 12; } }

        .table-striped>tbody>tr:nth-of-type(odd)>td { background-color: rgba(0, 0, 0, 0.02); }
        .table-hover>tbody>tr:hover>td { background-color: rgba(0, 0, 0, 0.05); }

        [data-theme="dark"] .table-custom td { background-color: var(--card-bg); }
        [data-theme="dark"] .table-striped>tbody>tr:nth-of-type(odd)>td { background-color: rgba(255, 255, 255, 0.03); }
        [data-theme="dark"] .table-hover>tbody>tr:hover>td { color: var(--text-dark); background-color: rgba(255, 255, 255, 0.08); }
        [data-theme="dark"] .table-light { background-color: #31334a !important; color: #fff !important; border-color: var(--border-color); }
        [data-theme="dark"] .table-light td { background-color: #31334a !important; color: #fff !important; }
        [data-theme="dark"] .alert-info { background-color: #27293d; border-color: #3498db; color: #e0e0e0; }

        #loading-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(255,255,255,0.9); z-index: 9999;
            display: flex; flex-direction: column; justify-content: center; align-items: center; display: none;
        }

        .nav-tabs { border-bottom: 2px solid var(--border-color); }
        .nav-tabs .nav-link { border: none; color: var(--text-muted); font-weight: 600; padding: 12px 25px; border-radius: 8px 8px 0 0; }
        .nav-tabs .nav-link.active { color: var(--primary-color); background-color: transparent; border-bottom: 3px solid var(--primary-color); }
        
        @media (max-width: 576px) {
            .nav-tabs { flex-wrap: nowrap; overflow-x: auto; overflow-y: hidden; white-space: nowrap; padding-bottom: 5px; }
            .nav-tabs::-webkit-scrollbar { height: 4px; }
            .nav-tabs::-webkit-scrollbar-thumb { background-color: var(--border-color); border-radius: 4px; }
        }

        .empty-state { text-align: center; padding: 80px 20px; background: var(--card-bg); border-radius: 12px; margin-top: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.04); border: 1px solid var(--border-color); }
        .empty-state h3 { color: var(--text-dark); }
        .dashboard-content { display: none; }
        .page-wrapper { max-width: 1440px; margin: 0 auto; width: 100%; }
        .modal-custom-width { max-width: 1440px !important; width: 95%; margin: 10px auto; }
        
        @media (max-width: 576px) {
            .upload-btn-wrapper { width: 100%; }
            .upload-btn-wrapper .btn { width: 100%; }
            .header-action-btns { width: 100%; }
            .header-action-btns > button, .header-action-btns > div { flex: 1 1 auto; width: 100%; }
            .table-custom th, .table-custom td { font-size: 0.8rem; }
            .table-custom .fs-5 { font-size: 1rem !important; }
            .table-custom .badge { font-size: 0.75rem; }
        }

        /* =======================================================================
           ESTILOS ADAPTADOS PARA A NOVA ABA (MATRIZ DE VENDAS / )
           Substitui as cores hardcoded pelo tema global dinâmico do Dashboard.
           ======================================================================= */
        #matriz-vendas-container {
            color: var(--text-dark);
            border-radius: 12px;
            overflow: hidden;
        }
        #matriz-vendas-container .card-bg { 
            background-color: var(--card-bg); 
            border: 1px solid var(--border-color); 
        }
        #matriz-vendas-container .table-header { 
            background-color: var(--primary-color) !important; 
            color: #ffffff; 
        }
        #matriz-vendas-container .table-row:hover td { 
            background-color: rgba(0, 0, 0, 0.05) !important; 
        }
        #matriz-vendas-container .table-row:hover td.sticky-col { 
            background-color: var(--bg-color) !important; /* Retira transparência ao passar o mouse */
        }
        [data-theme="dark"] #matriz-vendas-container .table-row:hover td { 
            background-color: rgba(255, 255, 255, 0.08) !important; 
        }
        [data-theme="dark"] #matriz-vendas-container .table-row:hover td.sticky-col { 
            background-color: #31334a !important; /* Retira transparência no tema escuro */
        }
        #matriz-vendas-container .table-border { border-color: var(--border-color); }
        #matriz-vendas-container .sticky-col { 
            position: sticky; left: 0; background-color: var(--card-bg); z-index: 10; 
        }
        #matriz-vendas-container thead th.sticky-col {
            background-color: var(--primary-color) !important;
            color: #ffffff !important;
            z-index: 20;
        }
        [data-theme="dark"] #matriz-vendas-container thead th.sticky-col {
            background-color: #27293d !important;
        }
        #matriz-vendas-container select { 
            background-color: var(--card-bg) !important; 
            color: var(--text-dark) !important; 
            border-color: var(--border-color) !important; 
        }
        #matriz-vendas-container option { 
            background-color: var(--card-bg); color: var(--text-dark); 
        }

        /* Cores Temáticas de Categoria Integradas ao Painel */
        #matriz-vendas-container .bg-limpeza { background-color: rgba(231, 76, 60, 0.08); }
        #matriz-vendas-container .bg-higiene { background-color: rgba(0, 206, 201, 0.08); }
        #matriz-vendas-container .bg-beleza { background-color: rgba(253, 121, 168, 0.08); }
        #matriz-vendas-container .bg-total { background-color: rgba(15, 76, 129, 0.05); font-weight: 600; }
        
        /* Cores Sólidas para Cabeçalhos (Acessibilidade e Contraste) */
        #matriz-vendas-container .bg-limpeza-solid { background-color: #e74c3c; color: #ffffff; }
        #matriz-vendas-container .bg-higiene-solid { background-color: #00cec9; color: #ffffff; }
        #matriz-vendas-container .bg-beleza-solid { background-color: #fd79a8; color: #ffffff; }
        #matriz-vendas-container .bg-total-solid { background-color: var(--primary-color); color: #ffffff; }
        [data-theme="dark"] #matriz-vendas-container .bg-total-solid { background-color: #3498db; color: #ffffff; }

        [data-theme="dark"] #matriz-vendas-container .bg-limpeza { background-color: rgba(231, 76, 60, 0.15); }
        [data-theme="dark"] #matriz-vendas-container .bg-higiene { background-color: rgba(0, 206, 201, 0.15); }
        [data-theme="dark"] #matriz-vendas-container .bg-beleza { background-color: rgba(253, 121, 168, 0.15); }
        [data-theme="dark"] #matriz-vendas-container .bg-total { background-color: rgba(52, 152, 219, 0.15); }

        .matriz-text-limpeza { color: #e74c3c !important; }
        .matriz-text-higiene { color: #00cec9 !important; }
        .matriz-text-beleza { color: #fd79a8 !important; }
        .matriz-text-total { color: var(--primary-color) !important; }
        [data-theme="dark"] .matriz-text-total { color: #3498db !important; }
    </style>
</head>
<body>

    <!-- Loading Overlay -->
    <div id="loading-overlay">
        <div class="spinner-border text-primary" role="status" style="width: 4rem; height: 4rem;">
            <span class="visually-hidden">Carregando...</span>
        </div>
        <h4 class="mt-4 text-dark text-center px-3" id="loading-text">Processando arquivos CSV...</h4>
        <p class="text-muted text-center px-3" id="loading-subtext">Isso pode levar alguns segundos dependendo do volume de dados.</p>
    </div>

    <!-- Header -->
    <header class="header-top">
        <div class="page-wrapper px-3 px-md-4 d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3">
            <div class="d-flex flex-column flex-sm-row align-items-center text-center text-sm-start gap-2">
                <img src="https://megamix.ind.br/wp-content/uploads/2017/06/condor-logo.png" alt="Logo Condor" style="height: 45px; object-fit: contain;">
                <div>
                    <h4 class="m-0" style="font-weight: 700; color: var(--header-title-color); transition: color 0.3s;">DASHBOARD COMERCIAL</h4>
                    <small style="color: var(--header-subtext-color) !important; transition: color 0.3s;">Acompanhamento de Vendas e Metas Condor</small>
                </div>
            </div>
            <div class="header-action-btns d-flex flex-wrap justify-content-center align-items-center gap-2">
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown" style="border-radius: 8px; font-weight: 600; background: var(--card-bg); color: var(--text-dark); border-color: var(--border-color);">
                        <i class="fas fa-palette me-2"></i> Temas
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                        <li><a class="dropdown-item" href="#" onclick="setTheme('default')"><i class="fas fa-circle me-2" style="color: #0f4c81;"></i> Padrão</a></li>
                        <li><a class="dropdown-item" href="#" onclick="setTheme('light-red-cards')"><i class="fas fa-square me-2" style="color: #fff0f0; border: 1px solid #ccc;"></i> Claro (Vermelho)</a></li>
                        <li><a class="dropdown-item" href="#" onclick="setTheme('red-bg')"><i class="fas fa-fill-drip me-2" style="color: #fadbd8;"></i> Fundo Vermelho</a></li>
                        <li><a class="dropdown-item" href="#" onclick="setTheme('dark')"><i class="fas fa-moon me-2" style="color: #2d3436;"></i> Escuro</a></li>
                    </ul>
                </div>
                
                <button class="btn text-white shadow-sm" onclick="syncFromGoogleDriveScript()" style="background-color: #009e5f; border-radius: 8px; font-weight: 600; border: none; transition: all 0.3s; padding: 0.5rem 1rem;">
                    <i class="fab fa-google-drive me-2"></i> Puxar via Script
                </button>

                <div class="upload-btn-wrapper">
                    <button class="btn btn-primary shadow-sm" style="border-radius: 8px; font-weight: 600; background-color: var(--primary-color); border-color: var(--primary-color); padding: 0.5rem 1rem;">
                        <i class="fas fa-folder-open me-2"></i> Upload Local
                    </button>
                    <input type="file" id="csv-upload" webkitdirectory directory multiple accept=".csv, .xlsx, .xls, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet, application/vnd.ms-excel" />
                </div>
            </div>
        </div>
    </header>

