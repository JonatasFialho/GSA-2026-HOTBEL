            function matrizIdentificarMes(f, d) {
                const n = f.toUpperCase(); const meses = ['JAN','FEV','MAR','ABR','MAI','JUN','JUL','AGO','SET','OUT','NOV','DEZ'];
                for(let i=0; i<12; i++) { if (n.includes(meses[i]) || n.includes('-' + String(i+1).padStart(2, '0'))) return meses[i]; }
                if (d && d.length > 0) {
                    const dtF = d[0]['DTINI'] || d[0]['DTFAT'] || '';
                    if (dtF.includes('/')) return meses[parseInt(dtF.split('/')[1]) - 1];
                }
                return 'GERAL';
            }

            function matrizLerArquivo(fileObj, isMetas, isScript = false) {
                return new Promise((resolve, reject) => {
                    const fN = fileObj.name.toLowerCase();
                    
                    if (isScript) {
                        // Leitura de Strings vindas do Google Apps Script
                        if (fN.endsWith('.csv')) {
                            Papa.parse(fileObj.content, { header: true, skipEmptyLines: true, complete: (r) => {
                                if (isMetas) { 
                                    let s = {}; 
                                    // CORREÇÃO: Utiliza a função para identificar o mês, em vez do nome bruto do arquivo
                                    const mes = matrizIdentificarMes(fileObj.name, r.data);
                                    s[mes] = r.data; 
                                    // Fallback: Se a identificação falhar, salva como GERAL
                                    s['GERAL'] = r.data; 
                                    resolve(s); 
                                } else resolve(r.data);
                            }, error: reject });
                        } else if (fN.endsWith('.xlsx') || fN.endsWith('.xls')) {
                            try {
                                let data;
                                if (fileObj.content.startsWith('UEs') || fileObj.content.match(/^[A-Za-z0-9+/=]+$/)) {
                                     data = fileObj.content;
                                } else {
                                     console.warn("Script enviou XLSX mas não está em base64. O arquivo será ignorado.");
                                     resolve(isMetas ? {} : []);
                                     return;
                                }
                                const wb = XLSX.read(data, {type: 'base64'});
                                if (isMetas) {
                                    let s = {}; wb.SheetNames.forEach(n => { const j = XLSX.utils.sheet_to_json(wb.Sheets[n], {defval: ""}); if(j.length > 0) s[n.toUpperCase()] = j; });
                                    resolve(s);
                                } else resolve(XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], {defval: ""}));
                            } catch(e) {
                                console.error("Falha ao tentar ler XLSX do script", e);
                                resolve(isMetas ? {} : []);
                            }
                        } else {
                            resolve(isMetas ? {} : []);
                        }
                    } else {
                        // Leitura de Objetos File do Upload Local
                        if (fN.endsWith('.csv')) {
                            Papa.parse(fileObj, { header: true, skipEmptyLines: true, encoding: "ISO-8859-1", complete: (r) => {
                                if (isMetas) { 
                                    let s = {}; 
                                    const mes = matrizIdentificarMes(fileObj.name, r.data);
                                    s[mes] = r.data;
                                    s['GERAL'] = r.data; // Fallback
                                    resolve(s); 
                                } else resolve(r.data);
                            }, error: reject });
                        } else if (fN.endsWith('.xlsx') || fN.endsWith('.xls')) {
                            const reader = new FileReader(); 
                            reader.onload = (e) => {
                                try {
                                    const data = new Uint8Array(e.target.result); const wb = XLSX.read(data, {type: 'array'});
                                    if (isMetas) { 
                                        let s = {}; wb.SheetNames.forEach(n => { const j = XLSX.utils.sheet_to_json(wb.Sheets[n], {defval: ""}); if(j.length > 0) s[n.toUpperCase()] = j; }); 
                                        resolve(s); 
                                    } else resolve(XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], {defval: ""}));
                                } catch (err) { reject(err); }
                            }; reader.readAsArrayBuffer(fileObj);
                        }
                    }
                });
            }

            function matrizCruzarDados() {
                const mapE = new Map(); const mapS = new Map(); 
                const sMes = document.getElementById('matriz-filtro-mes');
                const sSup = document.getElementById('matriz-filtro-supervisor');
                if(!sMes || !sSup) return;
                
                const mesSel = sMes.value; const supSel = sSup.value;
                
                // CORREÇÃO (Fallback de Busca): Tenta achar o mês selecionado, se não, usa 'GERAL' ou o que estiver disponível
                const metas = matrizDadosMetasPorMes[mesSel] || matrizDadosMetasPorMes['GERAL'] || Object.values(matrizDadosMetasPorMes)[0] || []; 
                const vendas = matrizDadosVendasPorMes[mesSel] || [];

                metas.forEach(row => {
                    // Usando inteligência de limpeza de título de colunas
                    const codRaw = row['CODRCA'] || row['CODVEND'] || row['COD.'] || findKeyPartial(row, 'CODVEND') || findKeyPartial(row, 'CODRCA') || findKeyPartial(row, 'COD');
                    const cod = String(codRaw || '').trim();
                    
                    const vendRaw = row['VENDEDOR'] || findKeyPartial(row, 'VENDEDOR');
                    const vend = String(vendRaw || '').trim(); 
                    
                    const supRaw = row['SUPERVISOR'] || findKeyPartial(row, 'SUPERVISOR');
                    const sup = String(supRaw || '').trim();
                    
                    if (!vend || vend === 'undefined' || vend === 'VENDEDOR') return;
                    
                    const isSub = (sup && vend.toUpperCase() === sup.toUpperCase()) || vend.toUpperCase().startsWith('TOTAL');
                    
                    if (sup && !mapS.has(sup)) {
                        mapS.set(sup, { 
                            cod: '', supervisor: sup, vendedor: sup + '', 
                            limpeza: { metaValor: 0, realValor: 0, metaPosit: 0, clientesSet: new Set() }, 
                            higiene: { metaValor: 0, realValor: 0, metaPosit: 0, clientesSet: new Set() }, 
                            beleza: { metaValor: 0, realValor: 0, metaPosit: 0, clientesSet: new Set() },
                            total: { metaValor: 0, realValor: 0, metaPosit: 0, clientesSet: new Set() }
                        });
                    }
                    
                    const sObj = mapS.get(sup);
                    if (!isSub) {
                        if (supSel === 'Todos' || sup === supSel) {
                            if (cod) {
                                // Aplicando conversão monetária super resistente a pontuação e formatação CSV corrompida
                                const mLim = parseMetaValue(row['META LIMPEZA'] || findKeyPartial(row, 'METALIMPEZA'));
                                const mHig = parseMetaValue(row['META HIGIENE BUCAL'] || row['META HIGIENE'] || findKeyPartial(row, 'METAHIGIENE'));
                                const mBel = parseMetaValue(row['META BELEZA'] || findKeyPartial(row, 'METABELEZA'));
                                
                                // APLICADO ARREDONDAMENTO PARA BAIXO (Math.floor) PARA METAS DE POSITIVAÇÃO
                                const mPosLim = Math.floor(parseMetaValue(row['POSIT LIMPEZA'] || findKeyPartial(row, 'POSITLIMPEZA')));
                                const mPosHig = Math.floor(parseMetaValue(row['POSIT HIGIENE BUCAL'] || row['POSIT HIGIENE'] || findKeyPartial(row, 'POSITHIGIENE')));
                                const mPosBel = Math.floor(parseMetaValue(row['POSIT BELEZA'] || findKeyPartial(row, 'POSITBELEZA')));
                                const mPosLhb = Math.floor(parseMetaValue(row['POSIT LHB'] || findKeyPartial(row, 'POSITLHB')));
                                
                                mapE.set(cod, { 
                                    cod, vendedor: vend, supervisor: sup, 
                                    limpeza: { metaValor: mLim, realValor: 0, metaPosit: mPosLim, clientesSet: new Set() }, 
                                    higiene: { metaValor: mHig, realValor: 0, metaPosit: mPosHig, clientesSet: new Set() }, 
                                    beleza: { metaValor: mBel, realValor: 0, metaPosit: mPosBel, clientesSet: new Set() },
                                    total: { metaValor: mLim + mHig + mBel, realValor: 0, metaPosit: mPosLhb, clientesSet: new Set() }
                                });
                                if (sObj) { 
                                    sObj.limpeza.metaValor += mLim; sObj.higiene.metaValor += mHig; sObj.beleza.metaValor += mBel;
                                    sObj.limpeza.metaPosit += mPosLim; sObj.higiene.metaPosit += mPosHig; sObj.beleza.metaPosit += mPosBel;
                                    sObj.total.metaPosit += mPosLhb; sObj.total.metaValor += (mLim + mHig + mBel);
                                }
                            }
                        }
                    }
                });

                vendas.forEach(row => {
                    const codRaw = row['CODVEND'] || row['CODRCA'] || findKeyPartial(row, 'CODVEND') || findKeyPartial(row, 'CODRCA');
                    const cod = String(codRaw || '').trim(); 
                    const vObj = mapE.get(cod);
                    
                    const supRaw = vObj ? vObj.supervisor : (row['SUPERVISOR'] || findKeyPartial(row, 'SUPERVISOR'));
                    const supN = String(supRaw || '').trim();
                    const sObj = mapS.get(supN);
                    
                    const depRaw = row['DEPARTAMENTO'] || row['CATEGORIA'] || findKeyPartial(row, 'DEPARTAMENTO') || findKeyPartial(row, 'CATEGORIA');
                    const dep = String(depRaw || '').toUpperCase();
                    
                    const valRaw = row['VLFAT'] || row['VLTOTAL'] || findKeyPartial(row, 'VLFAT');
                    const val = parseMetaValue(valRaw);

                    const codCliRaw = row['CODCLI'] || findKeyPartial(row, 'CODCLI') || '';
                    const codCli = String(codCliRaw).trim();
                    
                    let cat = dep.includes('LIM') ? 'limpeza' : (dep.includes('HIG') || dep.includes('HB') ? 'higiene' : (dep.includes('BEL') ? 'beleza' : null));
                    if (cat) { 
                        if (vObj) { 
                            vObj[cat].realValor += val; 
                            if (codCli) { vObj[cat].clientesSet.add(codCli); vObj.total.clientesSet.add(codCli); }
                        } 
                        if (sObj) { 
                            sObj[cat].realValor += val; 
                            if (codCli) { sObj[cat].clientesSet.add(codCli); sObj.total.clientesSet.add(codCli); }
                        } 
                    }
                });
                
                matrizDadosEquipe = Array.from(mapE.values()).sort((a,b) => a.vendedor.localeCompare(b.vendedor));
                matrizDadosSupervisores = Array.from(mapS.values()).filter(s => supSel === 'Todos' || s.supervisor === supSel).sort((a,b) => a.supervisor.localeCompare(b.supervisor));
            }
        })();
    </script>
