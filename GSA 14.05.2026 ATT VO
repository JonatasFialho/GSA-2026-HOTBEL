        function calculateKPIs() {
            let totalSellOut = 0; const clientesSet = new Set(), mesesFiltradosSet = new Set(), clientesPorMes = {};
            filteredData.forEach(row => {
                totalSellOut += row.VLFAT_NUM;
                if (row.CODCLI) {
                    clientesSet.add(row.CODCLI);
                    if (row.MES_EXTRATO && row.MES_EXTRATO !== '00') {
                        if (!clientesPorMes[row.MES_EXTRATO]) clientesPorMes[row.MES_EXTRATO] = new Set();
                        clientesPorMes[row.MES_EXTRATO].add(row.CODCLI);
                    }
                }
                if (row.MES_EXTRATO && row.MES_EXTRATO !== '00') mesesFiltradosSet.add(row.MES_EXTRATO);
            });

            const isAccumulated = (document.getElementById('filter-mes').value === "");
            let qtdClientesVisor = 0;
            if (isAccumulated) {
                let sumClientes = 0, countMeses = Object.keys(clientesPorMes).length;
                for (let m in clientesPorMes) sumClientes += clientesPorMes[m].size;
                qtdClientesVisor = countMeses > 0 ? Math.round(sumClientes / countMeses) : 0;
                document.getElementById('title-kpi-clientes').innerText = 'COBERTURA MÉDIA';
                document.getElementById('title-kpi-sellout').innerText = 'SELL OUT ACUMULADO';
                document.getElementById('title-kpi-gap').innerText = 'GAP ACUMULADO (R$)';
            } else {
                qtdClientesVisor = clientesSet.size;
                document.getElementById('title-kpi-clientes').innerText = 'COBERTURA MÊS';
                document.getElementById('title-kpi-sellout').innerText = 'SELL OUT MÊS';
                document.getElementById('title-kpi-gap').innerText = 'GAP MÊS (R$)';
            }

            const ticketMedio = clientesSet.size > 0 ? totalSellOut / clientesSet.size : 0;
            let metaCatToUse = 'TT';
            const deptFilterArray = getCustomSelectValues('filter-departamento');
            if (deptFilterArray.length === 1) { if (deptFilterArray[0] === 'LIM') metaCatToUse = 'LIM'; else if (deptFilterArray[0] === 'HIG') metaCatToUse = 'HIG'; else if (deptFilterArray[0] === 'BEL') metaCatToUse = 'BEL'; }

            let metaSellOut = 0, metaCoberturaTotal = 0;
            mesesFiltradosSet.forEach(m => { if(metas2026[m] && metas2026[m][metaCatToUse]) { metaSellOut += metas2026[m][metaCatToUse].sellout; metaCoberturaTotal += metas2026[m][metaCatToUse].cobertura; } });
            let metaCoberturaVisor = isAccumulated && mesesFiltradosSet.size > 0 ? Math.round(metaCoberturaTotal / mesesFiltradosSet.size) : metaCoberturaTotal;
            const metaTicket = metaCoberturaTotal > 0 ? metaSellOut / metaCoberturaTotal : 0;
            const gapValor = totalSellOut - metaSellOut;

            document.getElementById('kpi-sellout').innerText = formatCurrency(totalSellOut);
            document.getElementById('kpi-clientes').innerText = formatNumber(qtdClientesVisor);
            document.getElementById('kpi-ticket').innerText = formatCurrency(ticketMedio);
            document.getElementById('kpi-gap').innerText = (gapValor > 0 ? '+ ' : '') + formatCurrency(gapValor);
            document.getElementById('meta-sellout').innerText = `Meta: ${formatCurrency(metaSellOut)}`;
            document.getElementById('meta-clientes').innerText = `Meta: ${formatNumber(metaCoberturaVisor)}`;
            document.getElementById('meta-ticket').innerText = `Meta Planejada: ${formatCurrency(metaTicket)}`;
            document.getElementById('status-gap').innerText = gapValor >= 0 ? 'Superávit Gerado' : 'Déficit Gerado';

            const pSell = metaSellOut > 0 ? (totalSellOut / metaSellOut) * 100 : 0;
            const pCob = metaCoberturaVisor > 0 ? (qtdClientesVisor / metaCoberturaVisor) * 100 : 0;
            const pTick = metaTicket > 0 ? (ticketMedio / metaTicket) * 100 : 0;
            const pGap = metaSellOut > 0 ? (gapValor / metaSellOut) * 100 : 0;

            updateBadgeElement('badge-sellout', pSell); updateBadgeElement('badge-clientes', pCob); updateBadgeElement('badge-ticket', pTick);
            const badgeGap = document.getElementById('badge-gap');
            if (gapValor >= 0) { badgeGap.className = 'badge-custom badge-success'; badgeGap.innerHTML = `<i class="fas fa-arrow-trend-up"></i> ${Math.abs(pGap).toFixed(1)}%`; }
            else { badgeGap.className = 'badge-custom badge-danger'; badgeGap.innerHTML = `<i class="fas fa-arrow-trend-down"></i> -${Math.abs(pGap).toFixed(1)}%`; }
        }

