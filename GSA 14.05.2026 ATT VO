            tableData = Array.from(mapCidades.values()).map(v => {
                const hasAll = (v.lim > 0 && v.hig > 0 && v.bel > 0) ? 1 : 0;
                const status = hasAll ? '✅' : '⚠️';
                return { 
                    cidade: v.cidade, lim: v.lim, hig: v.hig, bel: v.bel, total: v.total, status: status, hasAll: hasAll
